generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  pushToken     String?
  banli         Boolean   @default(false)
  rozet         String?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  haberler          Haber[]
  yorumlar          Yorum[]
  yorumBegeni       YorumBegeni[]
  bildirimler       Bildirim[]
  kaydedilenHaberler KaydedilenHaber[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Haber {
  id            String   @id @default(cuid())
  baslik        String
  icerik        String   @db.Text
  hamIcerik     String   @db.Text
  fotografUrls  String[]
  fotografAlt   String?
  kategori      Kategori @default(GENEL)
  anonim        Boolean  @default(false)
  yazarAdi      String?
  yayinlandiMi  Boolean  @default(true)
  spam          Boolean  @default(false)
  spamNedeni    String?
  goruntuSayisi Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  yazarId  String?
  yazar    User?   @relation(fields: [yazarId], references: [id], onDelete: SetNull)
  yorumlar           Yorum[]
  kaydedilenHaberler KaydedilenHaber[]
}

model Yorum {
  id        String   @id @default(cuid())
  icerik    String   @db.Text
  createdAt DateTime @default(now())

  haberId String
  haber   Haber  @relation(fields: [haberId], references: [id], onDelete: Cascade)

  yazarId String?
  yazar   User?   @relation(fields: [yazarId], references: [id], onDelete: SetNull)

  begeniler YorumBegeni[]
}

model YorumBegeni {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  yorumId String
  yorum   Yorum  @relation(fields: [yorumId], references: [id], onDelete: Cascade)

  kullaniciId String
  kullanici   User   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@unique([yorumId, kullaniciId])
}

model Bildirim {
  id        String   @id @default(cuid())
  mesaj     String
  okundu    Boolean  @default(false)
  haberId   String?
  yorumId   String?
  createdAt DateTime @default(now())

  kullaniciId String
  kullanici   User   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
}

model Reklam {
  id         String   @id @default(cuid())
  baslik     String
  resimUrl   String
  tiklamaUrl String?
  aktif      Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model KaydedilenHaber {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  kullaniciId String
  kullanici   User   @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  haberId String
  haber   Haber  @relation(fields: [haberId], references: [id], onDelete: Cascade)

  @@unique([kullaniciId, haberId])
}

model Etkinlik {
  id        String   @id @default(cuid())
  baslik    String
  aciklama  String   @db.Text
  tarih     DateTime
  konum     String?
  createdAt DateTime @default(now())
}

model Anket {
  id        String          @id @default(cuid())
  soru      String
  aktif     Boolean         @default(true)
  createdAt DateTime        @default(now())
  secenekler AnketSecenegi[]
}

model AnketSecenegi {
  id       String      @id @default(cuid())
  metin    String
  anketId  String
  anket    Anket       @relation(fields: [anketId], references: [id], onDelete: Cascade)
  oylar    AnketOyu[]
}

model AnketOyu {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  secenekId   String
  secenek     AnketSecenegi @relation(fields: [secenekId], references: [id], onDelete: Cascade)
  anketId     String
  kullaniciId String

  @@unique([anketId, kullaniciId])
}

enum Role {
  USER
  ADMIN
}

enum Kategori {
  GENEL
  SPOR
  KULTUR
  EKONOMI
  EGITIM
  SAGLIK
  DUYURU
}
